# Paper-Graph Configuration Template
# Copy this to .env and fill in your API keys

# Required: Gemini API key for tag extraction
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Semantic Scholar API key for enhanced search features
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key

# Default paper sources to search (comma-separated)
DEFAULT_SOURCES=arxiv,pubmed,biorxiv

# Maximum number of papers to return per search
MAX_RESULTS_PER_SEARCH=20

# Tag extraction settings
TAG_EXTRACTION_TEMPERATURE=0.3
MAX_TAGS_PER_PAPER=15
MIN_TAG_CONFIDENCE=0.5

# Graph relationship settings
MIN_SHARED_TAGS_FOR_EDGE=1
AUTO_BUILD_RELATIONSHIPS=true

# File paths
DEFAULT_EXPORT_PATH=./exports
CACHE_DIRECTORY=./cache

# API rate limiting
API_DELAY_SECONDS=1.0
MAX_CONCURRENT_REQUESTS=5